# memd configuration — copy to .env (or export in your shell) and adjust.
# In production, set secrets with your platform's secret store rather than a
# committed file.

# --- Sessions -----------------------------------------------------------------
# Key used to encrypt the session cookie (AES-256-GCM). Set this in production
# so logins survive restarts and are stable across replicas. If unset, memd
# generates an ephemeral key and logins reset whenever the process restarts.
MEMD_SESSION_SECRET=change-me-to-a-long-random-string

# Absolute session-lifetime cap (Go duration, e.g. 12h, 24h). Default 24h.
# MEMD_SESSION_MAX_AGE=24h

# --- Account database ---------------------------------------------------------
# Optional override for the control-plane database. Defaults to a cgo-free
# SQLite file in the memd config directory.
# MEMD_DATABASE_URL=sqlite:///var/lib/memd/memd.db

# --- OpenID Connect (SSO) -----------------------------------------------------
# OIDC is normally configured by a super admin in the web UI (/admin), and the
# configuration is stored in the database. The variables below are only used to
# SEED that configuration on first boot — handy for automated deployments.
# Leave them all unset to start with local accounts only and configure SSO later.
#
# memd is IdP-agnostic: set these four and everything else (auth/token/jwks/
# end_session endpoints, signing algorithms) comes from discovery at
# <issuer>/.well-known/openid-configuration.
#
# OIDC_ISSUER_URL=https://idp.example.com/realms/memd
# OIDC_CLIENT_ID=memd
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=https://memd.example.com/auth/callback

# Optional. Space-separated scopes (default "openid profile email"). Add
# offline_access if your IdP requires it to issue refresh tokens.
# OIDC_SCOPES=openid profile email offline_access

# Optional authorization controls.
# OIDC_GROUPS_CLAIM=groups          # ID-token claim that lists group/role names
# OIDC_ADMIN_GROUP=memd-admins      # membership grants admin
# ADMIN_EMAILS=you@example.com      # comma-separated allowlist (for IdPs without groups)
# ADMIN_SUBJECTS=                   # comma-separated `sub` allowlist

# Optional RP-initiated logout target.
# OIDC_POST_LOGOUT_REDIRECT_URI=https://memd.example.com/
